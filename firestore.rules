rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Prototype Security Rules for AtollCargo
    // ===============================================================
    //
    // Assumed Data Model
    //
    // business_profiles/{businessProfileId}
    //   ownerUserId: string, businessName: string, vesselName: string,
    //   vesselRegistrationNumber: string, gstNumber: string,
    //   defaultTaxRate: number, taxInclusivePricingEnabled: bool,
    //   activeStatus: bool, createdAt: timestamp
    //
    // business_users/{uid}
    //   uid: string, businessProfileId: string, email: string,
    //   name: string, role: owner|admin|manager|cashier|loading_staff|offloading_staff|viewer,
    //   activeStatus: bool
    //
    // Tenant-scoped collections:
    //   business_profiles/{businessProfileId}/{collectionName}/{docId}
    //
    //   destinations, customers, catalog_items, item_price_rates, trips,
    //   operations, operation_items, bills, payments, tax_settings,
    //   numbering_sequences, audit_logs, notifications, pdf_documents,
    //   sync_conflicts.
    // Each tenant document must include businessProfileId: string.
    //
    // These are prototype rules. They default-deny unknown paths and require
    // Firebase Auth plus a matching business_users membership document.

    function isAuthenticated() {
      return request.auth != null;
    }

    function signedInUser() {
      return get(/databases/$(database)/documents/business_users/$(request.auth.uid));
    }

    function isBusinessMember(businessProfileId) {
      return isAuthenticated()
        && signedInUser().data.businessProfileId == businessProfileId
        && signedInUser().data.activeStatus == true;
    }

    function isManagerOrAbove() {
      return signedInUser().data.role in ['owner', 'admin', 'manager'];
    }

    function isOwnerOrAdmin() {
      return signedInUser().data.role in ['owner', 'admin'];
    }

    function ownsBusinessProfile(businessProfileId) {
      return exists(/databases/$(database)/documents/business_profiles/$(businessProfileId))
        && get(/databases/$(database)/documents/business_profiles/$(businessProfileId)).data.ownerUserId == request.auth.uid;
    }

    function validBusinessUser(data, uid) {
      return data.keys().hasOnly([
          'id', 'uid', 'businessProfileId', 'email', 'name', 'role',
          'avatar', 'online', 'activeStatus', 'createdAt', 'updatedAt'
        ])
        && data.uid == uid
        && data.id == uid
        && validBusinessProfileId(data)
        && validString(data.email, 3, 160)
        && validString(data.name, 1, 120)
        && data.role in ['owner', 'admin', 'manager', 'cashier', 'loading_staff', 'offloading_staff', 'viewer']
        && data.activeStatus is bool;
    }

    function validBusinessProfile(data, businessProfileId) {
      return data.keys().hasOnly([
          'id', 'ownerUserId', 'businessName', 'vesselName',
          'vesselRegistrationNumber', 'companyName',
          'companyRegistrationNumber', 'gstNumber',
          'taxRegistrationStatus', 'phone', 'email', 'address', 'logoEmoji',
          'defaultCurrency', 'defaultTaxRate',
          'taxInclusivePricingEnabled', 'activeStatus', 'createdAt', 'updatedAt'
        ])
        && data.id == businessProfileId
        && data.ownerUserId is string
        && validString(data.businessName, 1, 120)
        && validString(data.vesselName, 1, 120)
        && validString(data.vesselRegistrationNumber, 1, 80)
        && data.defaultCurrency == 'MVR'
        && data.defaultTaxRate is number
        && data.defaultTaxRate >= 0
        && data.defaultTaxRate <= 100
        && data.taxInclusivePricingEnabled is bool
        && data.activeStatus is bool;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function validBusinessProfileId(data) {
      return data.businessProfileId is string
        && data.businessProfileId.size() > 0
        && data.businessProfileId.size() <= 80;
    }

    function businessProfileUnchanged() {
      return request.resource.data.businessProfileId == resource.data.businessProfileId;
    }

    function createdAtUnchangedIfPresent() {
      return !('createdAt' in resource.data)
        || !('createdAt' in request.resource.data)
        || request.resource.data.createdAt == resource.data.createdAt;
    }

    function validCatalogItem(data) {
      return hasRequiredFields([
          'businessProfileId', 'itemName', 'itemCode', 'category',
          'unitType', 'defaultTaxRate', 'taxInclusive', 'activeStatus', 'icon'
        ])
        && hasOnlyAllowedFields([
          'id', 'businessProfileId', 'itemName', 'itemCode', 'category',
          'unitType', 'defaultTaxRate', 'taxInclusive', 'activeStatus',
          'icon', 'createdAt', 'updatedAt'
        ])
        && validBusinessProfileId(data)
        && validString(data.itemName, 1, 120)
        && validString(data.itemCode, 1, 24)
        && data.category in ['general_cargo', 'perishable', 'construction', 'fuel', 'vehicle', 'other']
        && data.unitType in ['kg', 'ton', 'piece', 'crate', 'sack', 'litre', 'm3', 'trip']
        && data.defaultTaxRate is number
        && data.defaultTaxRate >= 0
        && data.defaultTaxRate <= 100
        && data.taxInclusive is bool
        && data.activeStatus is bool
        && validString(data.icon, 1, 8);
    }

    function validPriceRate(data) {
      return hasRequiredFields([
          'businessProfileId', 'itemId', 'priceLevel', 'priceTaxInclusive'
        ])
        && hasOnlyAllowedFields([
          'id', 'businessProfileId', 'itemId', 'priceLevel', 'destinationId',
          'priceTaxInclusive', 'createdAt', 'updatedAt'
        ])
        && validBusinessProfileId(data)
        && validString(data.itemId, 1, 80)
        && data.priceLevel in ['standard', 'business', 'individual', 'government', 'walk_in', 'custom']
        && (!('destinationId' in data) || validString(data.destinationId, 1, 80))
        && data.priceTaxInclusive is number
        && data.priceTaxInclusive >= 0
        && data.priceTaxInclusive <= 10000000;
    }

    function validTenantDoc(data) {
      return validBusinessProfileId(data)
        && data.keys().hasOnly([
          'id', 'businessProfileId', 'createdAt', 'updatedAt', 'activeStatus',
          'name', 'displayName', 'legalName', 'phone', 'email', 'address',
          'islandName', 'atoll', 'destinationCode', 'sortOrder',
          'customerType', 'nationalIdOrRegNo', 'gstNumber',
          'defaultDestinationId', 'defaultPriceLevelId', 'creditAllowed',
          'creditLimit', 'outstandingBalance',
          'tripNumber', 'vesselName', 'originDestinationId', 'plannedDepartureAt',
          'actualDepartureAt', 'plannedArrivalAt', 'actualArrivalAt', 'status',
          'openedBy', 'endedBy', 'closedBy', 'notes', 'endedAt', 'closedAt',
          'operationType', 'destinationId', 'customerId', 'tripId',
          'items', 'totalTaxInclusive', 'totalTax', 'createdBy', 'synced',
          'operationId', 'itemId', 'itemNameSnapshot', 'unitType', 'quantity',
          'unitPriceTaxInclusive', 'taxRate', 'taxAmount', 'lineTotalTaxInclusive',
          'originalPrice', 'overridePrice', 'overrideReason',
          'billNumber', 'billType', 'billStatus', 'subtotalTaxInclusive',
          'taxTotal', 'grandTotal', 'paymentStatus', 'paidAmount',
          'finalizedBy', 'finalizedAt', 'itemCount',
          'paymentNumber', 'billId', 'amount', 'method', 'reference',
          'collectedBy', 'collectedAt',
          'taxName', 'taxRate', 'taxRegistrationStatus', 'taxInclusiveEnabled', 'effectiveFrom',
          'numberType', 'prefix', 'currentSequence', 'padding', 'formatTemplate',
          'lastGenerated',
          'actorUserId', 'action', 'entityType', 'entityId', 'summary',
          'title', 'body', 'read', 'type', 'variant', 'fileName', 'fileUrl',
          'readBy', 'conflictType', 'resolved'
        ]);
    }

    function canWriteOps() {
      return signedInUser().data.role in ['owner', 'admin', 'manager', 'loading_staff', 'offloading_staff'];
    }

    function canWriteBilling() {
      return signedInUser().data.role in ['owner', 'admin', 'manager', 'cashier'];
    }

    function canWritePayments() {
      return signedInUser().data.role in ['owner', 'admin', 'cashier'];
    }

    match /business_profiles/{businessProfileId} {
      allow read: if isBusinessMember(businessProfileId);
      allow create: if isAuthenticated()
        && request.resource.data.ownerUserId == request.auth.uid
        && validBusinessProfile(request.resource.data, businessProfileId);
      allow update: if isBusinessMember(businessProfileId)
        && isOwnerOrAdmin()
        && request.resource.data.ownerUserId == resource.data.ownerUserId
        && validBusinessProfile(request.resource.data, businessProfileId);
      allow delete: if false;

      match /business_users/{uid} {
        allow read: if isBusinessMember(businessProfileId);
        allow create: if isBusinessMember(businessProfileId)
          && validBusinessUser(request.resource.data, uid)
          && request.resource.data.businessProfileId == businessProfileId
          && (
            (
              request.auth.uid == uid
              && request.resource.data.role == 'owner'
            )
            || (
              isOwnerOrAdmin()
              && request.resource.data.role != 'owner'
            )
          );
        allow update: if isBusinessMember(businessProfileId)
          && validBusinessUser(request.resource.data, uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.businessProfileId == businessProfileId
          && request.resource.data.businessProfileId == resource.data.businessProfileId
          && (
            (
              request.auth.uid == uid
              && request.resource.data.role == resource.data.role
            )
            || (
              isOwnerOrAdmin()
              && resource.data.role != 'owner'
              && request.resource.data.role != 'owner'
            )
          );
        allow delete: if isOwnerOrAdmin()
          && request.auth.uid != uid
          && resource.data.role != 'owner'
          && resource.data.businessProfileId == businessProfileId;
      }

      match /vessels/{docId} {
        allow read, write: if false;
      }

      match /catalog_items/{itemId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && isManagerOrAbove()
          && validCatalogItem(request.resource.data);
        allow update: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && request.resource.data.businessProfileId == businessProfileId
          && isManagerOrAbove()
          && businessProfileUnchanged()
          && createdAtUnchangedIfPresent()
          && validCatalogItem(request.resource.data);
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && isOwnerOrAdmin();
      }

      match /item_price_rates/{rateId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && isManagerOrAbove()
          && validPriceRate(request.resource.data);
        allow update: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && request.resource.data.businessProfileId == businessProfileId
          && isManagerOrAbove()
          && businessProfileUnchanged()
          && createdAtUnchangedIfPresent()
          && validPriceRate(request.resource.data);
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && isOwnerOrAdmin();
      }

      match /trips/{tripId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create, update: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && canWriteOps();
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && isOwnerOrAdmin();
      }

      match /operations/{operationId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create, update: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && canWriteOps();
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && canWriteOps();
      }

      match /bills/{billId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create, update: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && canWriteBilling();
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && isOwnerOrAdmin();
      }

      match /payments/{paymentId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create, update: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && canWritePayments();
        allow delete: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && canWritePayments();
      }

      match /numbering_sequences/{sequenceId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create, update: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && canWriteBilling();
        allow delete: if false;
      }

      match /audit_logs/{auditId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data);
        allow update, delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isBusinessMember(businessProfileId);
        allow create: if isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data);
        allow update: if isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && request.resource.data.businessProfileId == businessProfileId
          && businessProfileUnchanged()
          && createdAtUnchangedIfPresent()
          && validTenantDoc(request.resource.data);
        allow delete: if isOwnerOrAdmin()
          && resource.data.businessProfileId == businessProfileId;
      }

      match /{collectionName}/{docId} {
        allow read: if collectionName != 'vessels'
          && isBusinessMember(businessProfileId);
        allow create: if collectionName != 'vessels'
          && isBusinessMember(businessProfileId)
          && request.resource.data.businessProfileId == businessProfileId
          && validTenantDoc(request.resource.data)
          && isManagerOrAbove();
        allow update: if collectionName != 'vessels'
          && isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && request.resource.data.businessProfileId == businessProfileId
          && businessProfileUnchanged()
          && createdAtUnchangedIfPresent()
          && validTenantDoc(request.resource.data)
          && isManagerOrAbove();
        allow delete: if collectionName != 'vessels'
          && isBusinessMember(businessProfileId)
          && resource.data.businessProfileId == businessProfileId
          && isOwnerOrAdmin();
      }
    }

    match /business_users/{uid} {
      allow read: if isAuthenticated()
        && (
          request.auth.uid == uid
          || isBusinessMember(resource.data.businessProfileId)
        );
      allow create: if isAuthenticated()
        && validBusinessUser(request.resource.data, uid)
        && (
          (
            request.auth.uid == uid
            && request.resource.data.role == 'owner'
            && ownsBusinessProfile(request.resource.data.businessProfileId)
          )
          || (
            isOwnerOrAdmin()
            && request.resource.data.role != 'owner'
            && request.resource.data.businessProfileId == signedInUser().data.businessProfileId
          )
        );
      allow update: if isAuthenticated()
        && validBusinessUser(request.resource.data, uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.businessProfileId == resource.data.businessProfileId
        && (
          (
            request.auth.uid == uid
            && request.resource.data.role == resource.data.role
          )
          || (
            isOwnerOrAdmin()
            && resource.data.role != 'owner'
            && request.resource.data.role != 'owner'
          )
        );
      allow delete: if isOwnerOrAdmin()
        && request.auth.uid != uid
        && resource.data.role != 'owner'
        && resource.data.businessProfileId == signedInUser().data.businessProfileId;
    }

    match /{collectionName}/{docId} {
      allow read, write: if false;
    }
  }
}
